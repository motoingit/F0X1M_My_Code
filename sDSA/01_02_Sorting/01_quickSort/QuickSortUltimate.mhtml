guage-c"><span>void quickSort(int arr[], int srt, int end, int depth){
    qs_calls++;
    if (depth &gt; max_depth)
        max_depth =3D depth;

    while (srt &lt; end) {
        int pivIdx =3D partitionFun(arr, srt, end);

        // Recurse on smaller partition
        if (pivIdx - srt &lt; end - pivIdx) {
            quickSort(arr, srt, pivIdx - 1, depth + 1);
            srt =3D pivIdx + 1;
        } else {
            quickSort(arr, pivIdx + 1, end, depth + 1);
            end =3D pivIdx - 1;
        }
    }
}
</span></code></div></div></pre>
