
{
  "version": "2.0.0",
    "label": "Compile and Run",
    "type": "shell",
    "command": "cmd.exe",
    "args": [
        "/c",
        "g++ -std=c++20 -O2 -Wall \"${file}\" -o \"${fileBasenameNoExtension}\" && ${fileBasenameNoExtension}.exe < input.txt > output.txt"
    ],
    "group": {
        "kind": "build",
        "isDefault": true
    },
    "problemMatcher": ["$gcc"]
}
